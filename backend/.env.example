APP_NAME=Cabana da Pizza API
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
API_V1_PREFIX=/api
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/cabana_pizza
DATABASE_CONNECT_TIMEOUT=3
POSTGRES_DB=cabana_pizza
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=
AUTH_SECRET_KEY=change-this-in-production-with-at-least-32-chars
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=480
ADMIN_ORDER_UNDO_WINDOW_MINUTES=10
ADMIN_BOOTSTRAP_NAME=Cabana Admin
ADMIN_BOOTSTRAP_EMAIL=admin@cabanadapizza.com
ADMIN_BOOTSTRAP_PASSWORD=troque-esta-senha
MEDIA_ROOT=./media
MEDIA_URL_PREFIX=/media
MEDIA_MAX_UPLOAD_MB=5
